# ── Telegram 凭证（必填）─────────────────────────────────────────────────────
# 请到 https://my.telegram.org/apps 获取
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=

# ── JWT 密钥（生产环境请修改）────────────────────────────────────────────────
JWT_SECRET=change-this-in-production

# ── MySQL 数据库 ────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=tgdownloader
DB_USER=root
DB_PASSWORD=

# ── 可选覆盖项 ──────────────────────────────────────────────────────────────
# DOWNLOAD_PATH=/data/downloads
# TEMP_PATH=/data/temp
